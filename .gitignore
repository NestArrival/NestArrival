# Shared repository ignores. App-specific build, env, and upload rules live in
# backend/.gitignore and frontend/.gitignore so each package can be managed
# independently.

.DS_Store
Thumbs.db
*.pem

npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

.env
.env.*
node_modules/
.next/
out/
coverage/
dist/
build/
.vercel/
*.tsbuildinfo
next-env.d.ts

.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
